@inherits LayoutComponentBase

<MudRTLProvider>
  <MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_currentTheme" />
  @* Required *@
  <MudPopoverProvider />

  @* Needed for dialogs *@
  <MudDialogProvider />

  @* Needed for snackbars *@
  <MudSnackbarProvider />

  <AuthorizeView>
    <NotAuthorized>
      <MudRTLProvider RightToLeft="_themePreference?.IsRTL ?? true">
        <MudLayout>
          <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh;">
            <MudPaper Elevation="25" Class="pa-8" Outlined>
              @Body
            </MudPaper>
          </MudContainer>
        </MudLayout>
      </MudRTLProvider>
    </NotAuthorized>
    <Authorized>
      <MudRTLProvider RightToLeft="_themePreference?.IsRTL ?? true">
        <MudLayout>
          <ThemeDrawer @bind-ThemeDrawerOpen="_themeDrawerOpen" ThemePreference="_themePreference"
                       ThemePreferenceChanged="ThemePreferenceChanged" />
          <ThemeButton OnClick="@(() => _themeDrawerOpen = true)" />
          <FSHMainLayout OnDarkModeToggle="ToggleDarkLightMode">
            @Body
          </FSHMainLayout>
        </MudLayout>
      </MudRTLProvider>
    </Authorized>
  </AuthorizeView>
</MudRTLProvider>