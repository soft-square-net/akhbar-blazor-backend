@using System.IO
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Helpers
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Models
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Services.Interfaces;
@implements System.IDisposable


<MudTreeView Dense @ref="FoldersTreeView" T="FolderModel" Items="_treeItems" Hover AutoExpand="@AutoExpand"
             ReadOnly="false"
             SelectedValue="@SelectedTreeItemData">
  @*              Expanded="@context.Value.IsExpanded" *@
  <ItemTemplate Context="TItem">
    <MudTreeViewItem T="FolderModel" Text="@(TItem.Text)"
                     Expanded="@TItem.Value.IsExpanded"
                     SelectedChanged="@((bool selected) => HandleSelectedChanged(selected, TItem))"
                     ExpandedChanged="@((bool isExpanded) => OnExpandedChanged(isExpanded, TItem))"
                     Value="@TItem.Value"
                     Items="@TItem.Children"
                     Icon="@(TItem.Value != null?GetIcon(TItem):null)"
                     IconExpanded="@Icons.Custom.Uncategorized.FolderOpen"
                     EndIcon="@Icons.Material.Outlined.Refresh"
                     EndIconColor="Color.Secondary" >
      <BodyContent>

        @* <div class="d-flex align-center flex-grow-1">
          <span class="mud-tree-view-item-content-text">@TItem.Text</span>

          <MudSpacer />

          <MudIconButton Icon="@Icons.Material.Outlined.Refresh" 
                         OnClick="@(async () => await OnEndIconClick(TItem))"
                         @onmousedown:stopPropagation="true" />
        </div> *@
        <div style="display: grid; grid-template-columns: 1fr auto; align-items: center; width: 100%">
          <MudText Style="justify-self: start;">@TItem.Text</MudText>
          <div style="justify-self: end;">
            <MudIconButton Icon="@Icons.Material.Outlined.Refresh" Size="Size.Medium" Color="Color.Inherit" OnClick="@(async () => await OnEndIconClick(TItem))"
                           @onmousedown:stopPropagation="true" />
          </div>
        </div>
      </BodyContent>
    </MudTreeViewItem>

  </ItemTemplate>
</MudTreeView>

@if (CurrentFolder != null)
{
  <MudText Typo="Typo.body1" Class="mt-4">
    Selected: <b>@CurrentFolder.Path</b>
  </MudText>
}

