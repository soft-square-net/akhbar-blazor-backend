@page "/workflow-instances"
@using FSH.Starter.Blazor.Modules.ElsaWorkflow.Blazor.Components
@using Microsoft.AspNetCore.Components.Sections
@using Microsoft.AspNetCore.Components.Web

@rendermode InteractiveWebAssembly
@* @layout ElsaWorkflow.Blazor.Layout.LayoutWorkflow *@


<WorkflowInstanceListWrapper ViewWorkflowInstance="@OnViewWorkflowInstance"/>


@code {

    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private void OnViewWorkflowInstance(string instanceId)
    {
        NavigationManager.NavigateTo($"workflow-instances/{instanceId}");
    }

}