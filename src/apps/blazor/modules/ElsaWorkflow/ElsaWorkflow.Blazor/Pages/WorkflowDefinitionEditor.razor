    private async Task InjectExternalScript(string scriptUrl)
    {
        // string scriptUrl = "cloudflare.com";

        // Complete script injection code executed in a single atomic JS call
        string injectorPayload = $@"
            if (!document.querySelector('script[src=""{scriptUrl}""]')) {{
                var script = document.createElement('script');
                script.src = '{scriptUrl}';
                script.async = true;
                document.head.appendChild(script);
            }}";

        // Injects the tag into <head> immediately
        await JS.InvokeVoidAsync("Function", injectorPayload);
    }
