@using System.IO
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Models
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Services.Interfaces;

@using MudBlazor

<MudTreeView T="FolderModel" Items="_treeItems" Hover="true"
             ReadOnly="false"
             SelectedValue="SelectedTreeItemData">

  <ItemTemplate>
    <MudTreeViewItem T="FolderModel" Text="@(context.Text)"
                     SelectedChanged="@((bool selected) => HandleSelectedChanged(selected, context))"
                     Expanded="@context.Expanded"
                     ExpandedChanged="@((bool isExpanded) => OnExpandedChanged(isExpanded, context))"
                     Value="@context.Value"
                     Items="@context.Children"
                     Icon="@(context.Value != null?GetIcon(context):null)"
                     IconExpanded="@Icons.Custom.Uncategorized.FolderOpen" 
                     EndIcon="@Icons.Material.Outlined.Refresh" 
                     EndIconColor="Color.Secondary"
                     />

  </ItemTemplate>
</MudTreeView>

@if (SelectedNode != null)
{
  <MudText Typo="Typo.body1" Class="mt-4">
    Selected: <b>@SelectedNode.Path</b>
  </MudText>
}

@code {
  [Inject] IFileExplorerStateService StateService { get; set; } = default!;

  // [Parameter] public required ICollection<FolderModel> Folders { get; set; }
  [CascadingParameter(Name = "Folders")] public required List<FolderModel> Folders { get; set; }
  [Parameter] public EventCallback<TreeItemData<FolderModel>> OnNodeSelected { get; set; }
  [Parameter] public EventCallback<ICollection<FolderModel>> OnFolderUpdated { get; set; }

  private List<TreeItemData<FolderModel>> _treeItems = new();
  private FolderModel? SelectedTreeItemData { get; set; }

  public FolderModel? SelectedNode => SelectedTreeItemData;

  // private IReadOnlyCollection<TreeItemData<FolderModel>> _items => Items.Select(f => new TreeItemData<FolderModel> { Value = f }).ToList().AsReadOnly();
  protected override void OnInitialized()
  {
    StateService.OnFolderUpdated += HandleOnFolderUpdated;
    // Replace with your target Windows directory path
    string targetPath = @"C:\YourTargetFolder";

    if (Directory.Exists(targetPath))
    {
      // var rootNode = LoadDirectory(targetPath);
      // Items = new List<TreeItemData<FolderModel>> { rootNode };
    }
    // 2. Convert your existing raw list (_items) into MudBlazor's collection format
    _treeItems = MapFoldersToTreeItemData(Folders);

  }

  private async Task HandleOnFolderUpdated(FolderModel model)
  {
    // ensure the component re-renders on the UI thread
    await InvokeAsync(StateHasChanged);
  }

  private List<TreeItemData<FolderModel>> MapFoldersToTreeItemData(ICollection<FolderModel> folders)
  {
    if (folders == null) return new List<TreeItemData<FolderModel>>();

    return folders.Select(f => new TreeItemData<FolderModel>
    {
      Value = f,
      Text = f.Name,
      // Recursively maps all levels of your child sub-folders safely
      Children = f.Folders != null ? MapFoldersToTreeItemData(f.Folders) : null
    }).ToList();
  }


  private async Task HandleSelectedChanged(bool selected, ITreeItemData<FolderModel> context)
  {
    if (selected)
    {
      FolderModel rawFolder = context.Value;
      SelectedTreeItemData = context.Value;
      await OnNodeSelected.InvokeAsync(context as TreeItemData<FolderModel>);
      // Your custom logic runs cleanly here for both parents and nested children
    }
    else
    {
      // if the item that became unselected was the currently selected node, clear the selection
      if (SelectedTreeItemData == context.Value)
      {
        SelectedTreeItemData = null;
      }
    }

    // ensure the component re-renders on the UI thread
    await InvokeAsync(StateHasChanged);
  }

  private string GetIcon(ITreeItemData<FolderModel> item)
  {
    if (item.Value.IsFolder)
    {
      return item.Expanded ? Icons.Custom.Uncategorized.FolderOpen : Icons.Custom.Uncategorized.Folder;
    }

    // Quick extension check for icons
    var ext = Path.GetExtension(item.Value.Name).ToLower();
    return ext switch
    {
      ".json" or ".cs" or ".xml" => Icons.Custom.FileFormats.FileCode,
      ".png" or ".jpg" or ".jpeg" => Icons.Custom.FileFormats.FileImage,
      _ => Icons.Material.Filled.DeviceUnknown
    };
  }

  private async Task OnExpandedChanged(bool isExpanded, ITreeItemData<FolderModel> node)
  {
    // Update the visual property state
    node.Value.IsExpanded = isExpanded;

    // Perform conditional action on expand
    if (isExpanded && (node.Value.Folders == null || !node.Value.Folders.Any()))
    {
      await node.Value.LoadFolders(); // LoadChildDataAsync(node);
    }
  }



  // Recursive function to load folders and files
  private TreeItemData<FolderModel> LoadDirectory(string path)
  {
    var di = new DirectoryInfo(path);
    var node = new TreeItemData<FolderModel>
    {
      // Value = new FolderModel(di.Name,di.GetFiles(),[])
      Value = new FolderModel(di.Name, null, [])
    };

    try
    {
      // 1. Populate Subdirectories recursively
      foreach (var dir in di.GetDirectories())
      {
        node.Children.Append(LoadDirectory(dir.FullName));
      }

      // 2. Populate Files
      foreach (var file in di.GetFiles())
      {
        node.Value.AddFile(new FileModel(Guid.NewGuid(), file.Name, file.Length, file.CreationTime, file.LastWriteTime));
      }
    }
    catch (UnauthorizedAccessException)
    {
      // Handle or log permission errors for restricted system folders
    }

    return node;
  }


}