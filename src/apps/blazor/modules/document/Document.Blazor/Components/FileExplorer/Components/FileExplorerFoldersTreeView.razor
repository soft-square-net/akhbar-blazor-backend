    }
    // 2. Convert your existing raw list (_items) into MudBlazor's collection format


  }


  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      StateService.OnCurrentFolderChanged += HandleOnCurrentFolderChanged;
      StateService.OnFolderUpdated += HandleOnFolderUpdated;
      StateService.OnFolderCreated += HandleOnFolderCreated;
      StateService.OnFolderSelectionChanged += HandleOnFolderSelectionChanged;
      _treeItems = MapFoldersToTreeItemData(Folders);
      // Optionally, select the first folder in the tree on initial render
      if (Folders.Any())
      {
        await SelectAsync(Folders.First());
      }
    }

  }
  private async Task HandleOnCurrentFolderChanged(FolderModel folder)
  {
    // ensure the component re-renders on the UI thread
    // await SelectAsync(model);
    if (TreeViewHelper<FolderModel>.GetByIdAndSelect(Folders, SelectedTreeItemData.Id, out var currentTreeFolder))
    {
      currentTreeFolder.Select();
    }
    CurrentFolder = folder;
    // folder.Select();
    _treeItems = MapFoldersToTreeItemData(Folders);
    await InvokeAsync(StateHasChanged);
  }

  private async Task OnEndIconClick(ITreeItemData<FolderModel> item)
  {
    if (item.Value != null)
    {
      // Handle the end icon click event for the specific folder
      // For example, you can delete the folder or perform any other action
      await StateService.NotifyFolderDeleted(item.Value);
      // Optionally, remove the folder from the tree view
      if (TreeViewHelper<FolderModel>.GetByIdAndSelect(_treeItems, item.Value.Id, out var matchedNode))
      {
        matchedNode.Value.Folder?.Folders.Remove(matchedNode.Value);
        await InvokeAsync(StateHasChanged);
      }
    }
  }

  private async Task HandleOnFolderSelectionChanged(BaseExplorerItemModel model)
  {
    await InvokeAsync(StateHasChanged);
  }

  private async Task SelectAsync(FolderModel folder)
  {
    TreeViewHelper<FolderModel>.GetByIdAndSelect(_treeItems, folder.Id, out var matchedNode);
    CurrentFolder = matchedNode?.Value ?? folder;
    SelectedTreeItemData = matchedNode?.Value;
  }

