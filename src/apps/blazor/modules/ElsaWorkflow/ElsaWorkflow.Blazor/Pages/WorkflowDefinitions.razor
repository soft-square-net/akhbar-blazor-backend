@page "/workflow-definitions"
@using FSH.Starter.Blazor.Modules.ElsaWorkflow.Blazor.Components
@using FSH.Starter.BlazorShared.Layout
@using Microsoft.AspNetCore.Components.Sections
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveWebAssembly
@* @layout ElsaWorkflow.Blazor.Layout.LayoutWorkflow *@


<WorkflowDefinitionListWrapper EditWorkflowDefinition="@OnEditWorkflowDefinition" />


@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    
    private void OnEditWorkflowDefinition(string definitionId)
    {
        NavigationManager.NavigateTo($"workflow-definitions/{definitionId}");
    }
}