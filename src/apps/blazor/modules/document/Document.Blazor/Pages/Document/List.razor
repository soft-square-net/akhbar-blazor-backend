@page "/document/list"
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Components
@using FSH.Starter.BlazorShared
@inherits MobulePageBase
@inject IDialogService DialogService
@using Microsoft.Extensions.Localization
@using FSH.Starter.Blazor.Modules.Document.Blazor
@inject IStringLocalizer<DocumentsResources> Loc


<MudButton @onclick="OpenDialogAsync" Variant="Variant.Filled" Color="Color.Primary">
  @Loc["ModulesDocumentTitle"] Open File Explorer
</MudButton>

<MudText Typo="Typo.h6">@_content</MudText>

<FileExplorerComponent AllowMultipleSelection="false" />

<img src="@_content/Pic01.png" style="width:100%"/>