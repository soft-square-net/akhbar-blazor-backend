@page "/storage/buckets"
@using FSH.Starter.BlazorShared.Components.EntityTable;
@using FSH.Starter.Blazor.Infrastructure.Api;
@using FSH.Starter.BlazorShared
@using FSH.Starter.BlazorShared.Components.General
@inherits MobulePageBase
@inject IDialogService DialogService


<PageHeader Title="Buckets" Header="Buckets" SubHeader="Manage your Buckets." />

<EntityTable @ref="_table" TEntity="BucketResponse" TId="Guid" TRequest="BucketVM" Context="@Context">

  <EditFormContent>

    @{
      // bool IsCreate = Context.AddEditModal.IsCreate;
      bool IsCreate = context.Id == Guid.Empty;
    }
    }
    @if (!IsCreate)
    {
      <MudItem xs="12" md="12">
        <MudTextField Value="context.Id" Underline=false ReadOnly Label="Id" />
      </MudItem>
    }   
    <MudItem xs="12" md="5">
      @* <MudSelect T="Guid?" Label="Account" Value="context.StorageAccountId" ValueChanged="() => StorageAccountValueChanged(context.StorageAccountId)"> *@
      <MudSelect T="Guid?" Label="Account" Value="context.StorageAccountId" ValueChanged="StorageAccountValueChanged">
        @foreach (var sa in _storageAccounts)
        {
          <MudSelectItem T="Guid?" Value="sa?.Id">@sa?.AccountName</MudSelectItem>
        }
      </MudSelect>
    </MudItem>
   
    <MudItem xs="12" md="6">
      <MudSelect T="string" Label="Region" @bind-Value="context.Region">
        @foreach (var region in _regions)
        {
          <MudSelectItem T="string" Value="region?.SystemName">@region?.DisplayName</MudSelectItem>
        }
      </MudSelect>
    </MudItem>
    <MudItem xs="12" md="12">
      <MudTextField Label="Name" For="@(() => context.Name)" @bind-Value="context.Name" />
    </MudItem>
    <MudItem xs="12" md="12">
      <MudTextField Lines="3" MaxLines="3" Variant="Variant.Outlined" Label="Description" For="@(() => context.Description)" @bind-Value="context.Description" />
    </MudItem>

        

    <MudItem xs="12" md="12">
      <MudItem>
        <div>
          @if (!IsCreate)
          {
            <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Info" Size="Size.Small" Target="_blank"
                       StartIcon="@Icons.Material.Filled.RemoveRedEye" Style="margin-left: 5px;">
              View!!
            </MudButton>

            <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete" Style="margin-left: 5px;">
              Delete!!
            </MudButton>
          }
        </div>
      </MudItem>
    </MudItem>
  </EditFormContent>

</EntityTable>