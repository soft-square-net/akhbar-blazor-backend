@using MudBlazor
@using Microsoft.AspNetCore.Components.Forms
@using FSH.Starter.Blazor.Modules.Document.Blazor.Components.FileExplorer.Dialogs

@*  <MudGrid Spacing="1" Style="height:calc(100% - 70px); min-height:500px;">
  <MudText Typo="Typo.body2" Color="Color.Error">@CurrentFolder</MudText> *@
<CascadingValue Value="@CurrentFolder" Name="CurrentFolder">
  <MudPaper Style="overflow:hidden; position:relative;min-height:500px;">
    <MudDrawerContainer Class="mud-height-full">
      <MudDrawer @bind-Open="@_open" Elevation="0" Variant="@DrawerVariant.Persistent" Color="Color.Primary">
        <MudPaper Outlined="false" Class="pa-0 px-2 mud-height-full" Elevation="0">
          <FileExplorerFoldersListComponent Folders="Folders" OnFolderSelected="OnFolderSelected" />
        </MudPaper>
      </MudDrawer>
      <MudPaper Class="pa-1 mt-1" Style="height:calc(100% - 0px);" Elevation="0">
        <FileExplorerContentComponent Folders="Folders" OnFolderUpdated="OnFolderUpdated" OnToggleFileBrowserTree="ToggleFileBrowserTree" />
      </MudPaper>
    </MudDrawerContainer>
  </MudPaper>
  @* </MudGrid> *@
</CascadingValue>

<style>
  :root {
    --file-explorer-breadcrumb-height: 3.5rem;
    --inner-shadow: inset 0px 2px 1px -1px rgba(0, 0, 0, 0.2), 0px 1px 1px 0px rgba(0, 0, 0, 0.14), 0px 1px 3px 0px rgba(0, 0, 0, 0.12);
  }

  .truncate {
    max-width: 150px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>